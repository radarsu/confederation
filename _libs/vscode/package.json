{
    "name": "@confederation/vscode",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "displayName": "Confederation Env Manager",
    "description": "Manage .env files against confederation.config schemas with validation, encryption, and a cross-service overview.",
    "publisher": "confederation",
    "main": "./dist/extension.cjs",
    "engines": {
        "vscode": "^1.96.0",
        "node": "24.14.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:**/confederation.config.{ts,mts,cts,js,mjs,cjs}"
    ],
    "contributes": {
        "customEditors": [
            {
                "viewType": "confederation.envEditor",
                "displayName": "Confederation Env Manager",
                "selector": [
                    {
                        "filenamePattern": ".env"
                    },
                    {
                        "filenamePattern": ".env.*"
                    }
                ],
                "priority": "default"
            }
        ],
        "commands": [
            {
                "command": "confederation.openEnvManager",
                "title": "Open Env Manager",
                "category": "Confederation"
            },
            {
                "command": "confederation.rescan",
                "title": "Re-scan Config & Env Files",
                "category": "Confederation"
            },
            {
                "command": "confederation.openAsPlainText",
                "title": "Open .env as Plain Text",
                "category": "Confederation"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "confederation.openEnvManager",
                    "when": "confederation.isConfederationRepo"
                },
                {
                    "command": "confederation.rescan",
                    "when": "confederation.isConfederationRepo"
                }
            ]
        },
        "configuration": {
            "title": "Confederation Env Manager",
            "properties": {
                "confederation.configFileGlob": {
                    "type": "string",
                    "default": "**/confederation.config.{ts,mts,cts,js,mjs,cjs}",
                    "description": "Glob used to discover confederation config definition files."
                },
                "confederation.envFileGlob": {
                    "type": "string",
                    "default": "**/.env*",
                    "description": "Glob used to discover .env files."
                },
                "confederation.exclude": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/node_modules/**",
                        "**/dist/**",
                        "**/.cache/**",
                        "**/.turbo/**",
                        "**/.git/**"
                    ],
                    "description": "Glob patterns excluded from discovery."
                },
                "confederation.nodePath": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to a Node.js 24+ binary used to evaluate confederation.config files. Defaults to `node` on PATH."
                },
                "confederation.configHostTimeoutMs": {
                    "type": "number",
                    "default": 10000,
                    "description": "Timeout in milliseconds for a single config-host introspect/validate request."
                }
            }
        }
    },
    "scripts": {
        "build": "node esbuild.config.mjs && tsc -p tsconfig.json && tsc -p tsconfig.webview.json",
        "watch": "node esbuild.config.mjs --watch",
        "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.webview.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@confederation/core": "workspace:*",
        "tslib": "catalog:"
    },
    "devDependencies": {
        "@confederation/tsconfig": "workspace:*",
        "@types/node": "catalog:",
        "@types/vscode": "catalog:",
        "esbuild": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:",
        "zod": "catalog:"
    }
}
