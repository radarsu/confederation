{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "node esbuild.config.mjs",
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": []
        },
        {
            "label": "watch",
            "type": "shell",
            "command": "node esbuild.config.mjs --watch",
            "options": { "cwd": "${workspaceFolder}" },
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}
