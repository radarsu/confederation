{
    "name": "@confederation/core",
    "version": "0.0.0",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/confederation.git",
        "directory": "_libs/core"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "exports": {
        "./index.js": {
            "types": "./dist/index.d.ts",
            "import": {
                "@confederation/src": "./src/index.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "@confederation/src": "./src/index.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --build --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@noble/post-quantum": "catalog:",
        "tslib": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@confederation/tsconfig": "workspace:*",
        "type-fest": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
