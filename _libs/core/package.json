{
    "name": "@puristic/env",
    "version": "0.0.0",
    "description": "Type-safe configuration loader: one real Zod schema drives runtime loading, validation, codegen, and post-quantum encrypted secrets — no DSL, no cloud.",
    "keywords": [
        "env",
        "dotenv",
        "dotenvx",
        "varlock",
        "environment-variables",
        "env-vars",
        "config",
        "configuration",
        "zod",
        "schema",
        "validation",
        "type-safe",
        "typescript",
        "secrets",
        "encryption",
        "post-quantum",
        "12-factor"
    ],
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/puristic-env.git",
        "directory": "_libs/core"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "exports": {
        "./index.js": {
            "types": "./dist/index.d.ts",
            "import": {
                "@puristic/src": "./src/index.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "@puristic/src": "./src/index.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --build --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@noble/post-quantum": "catalog:",
        "tslib": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@puristic/tsconfig": "workspace:*",
        "type-fest": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
